<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.markdown.editor.mapper.GroupMemberMapper">

    <select id="selectByGroupId" resultType="com.markdown.editor.entity.GroupMember">
        SELECT * FROM group_members WHERE group_id = #{groupId}
    </select>

    <select id="selectByUserId" resultType="com.markdown.editor.entity.GroupMember">
        SELECT * FROM group_members WHERE user_id = #{userId}
    </select>

    <select id="selectByGroupIdAndUserId" resultType="com.markdown.editor.entity.GroupMember">
        SELECT * FROM group_members WHERE group_id = #{groupId} AND user_id = #{userId}
    </select>

</mapper>